{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**"],
      "dependsOn": ["^build"]
    },
    "db:migrate": {
      "dependsOn": ["^db:migrate"]
    },
    "credential-showcase-api-server#build": {
      "dependsOn": [
        "^build"
      ],
      "env": [
        "DB_URL"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "generate:models": {
      "dependsOn": ["^generate:models"],
      "outputs": [
        "src/**"
      ]
    }
  }
}
